<Window x:Class="StudentFileWorkTask.presentation.ColumnMappingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сопоставление столбцов" Height="550" Width="600"
        WindowStartupLocation="CenterOwner" Background="#F5F5F5">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Сопоставьте столбцы из файла" 
                   FontSize="16" FontWeight="Bold" Foreground="#81A6C6" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="Загрузить шаблон" Width="137" Click="LoadTemplate_Click"
                    Style="{StaticResource RoundButton}" Background="#81A6C6" Margin="0,0,10,0"/>
            <Button Content="Сохранить шаблон" Width="141" Click="SaveTemplate_Click"
                    Style="{StaticResource RoundButton}" Background="#81A6C6"/>
        </StackPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="mainPanel">
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Студент (ФИО)" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="cmbStudent"/>
                    </Grid>
                </Border>

                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Группа" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="cmbGroup"/>
                    </Grid>
                </Border>

                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Дата" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="cmbDate"/>
                    </Grid>
                </Border>

                <TextBlock Text="Вопросы и баллы" FontWeight="Bold" Foreground="#81A6C6" Margin="0,10,0,8"/>

                <StackPanel x:Name="questionsPanel"/>

                <Button Content="+ Добавить вопрос" Click="AddQuestion_Click" Width="150" Margin="0,5,0,0"
                        Style="{StaticResource RoundButton}" Background="#81A6C6"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Авто" Click="AutoMapping_Click" Width="80" Margin="0,0,10,0"
                    Style="{StaticResource RoundButton}" Background="#81A6C6"/>
            <Button Content="OK" Click="Ok_Click" Width="80" Margin="0,0,10,0"
                    Style="{StaticResource RoundButton}" Background="#81A6C6"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="80"
                    Style="{StaticResource RoundButton}" Background="#FFB3B3"/>
        </StackPanel>
    </Grid>
</Window>